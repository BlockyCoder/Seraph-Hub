    end)

    local textBox = Library:TextBox(tab1Holder, "Enter Key here:", _G.Key or "Enter key here", function(txt)
        KeyLabel:UpdateLabel("Key > " .. txt)
        _G.Key = txt
        CheckKey()
    end)

    Library:Keybind(tab2Holder, "Key bind", Enum.KeyCode.K, function()
