-- Server-based Admin Check
local function isAdmin()
    local isAdminCheck = false
    local success, errorMessage = pcall(function()
        local adminResponse = game:HttpGet("https://your-secure-server.com/checkAdmin?username=" .. player.Name)
        if adminResponse == "true" then
            isAdminCheck = true
        end
    end)
    
    if not success then
        Library:ShowNotify("Admin Check Error", "Error contacting server: " .. errorMessage, 5)
    end

    return isAdminCheck
end

-- Encrypt Keys to secure file storage
local function encryptKeys(keys)
    local keyString = table.concat(keys, ",")
    return HttpService:GenerateGUID(keyString)
end

-- Save encrypted keys
local function saveKeysToFile(keys)
    local success, errorMessage = pcall(function()
        local encryptedKeys = encryptKeys(keys)
        local data = {Keys = encryptedKeys}
        local jsonData = HttpService:JSONEncode(data)
        writefile(FileName, jsonData)
    end)

    if success then
        Library:ShowNotify("Save Success", "Keys successfully saved in encrypted format.", 5)
    else
        Library:ShowNotify("Save Error", "Error saving keys to file: " .. errorMessage, 5)
    end
end

-- Get latest valid key, validated through server-side checks
local function getLatestValidKey()
    local validKey = nil
    local success, errorMessage = pcall(function()
        if isfile(FileName) then
            local jsonData = readfile(FileName)
            local data = HttpService:JSONDecode(jsonData)
            local encryptedKeys = data.Keys
            -- Decrypt keys locally (optional for extra layer)
            local keys = {encryptedKeys}

            for _, key in ipairs(keys) do
                -- Validate through the server-side API
                local keyResponse = game:HttpGet("https://your-secure-server.com/validateKey?key=" .. key)
                
                if keyResponse == "true" then
                    validKey = key
                    Library:ShowNotify("Valid Key", "Valid key found!", 5)
                    break
                end
            end
        else
            Library:ShowNotify("File Error", "Key file does not exist.", 5)
        end
    end)

    if not success then
        Library:ShowNotify("Retrieval Error", "Error retrieving keys from file: " .. errorMessage, 5)
    end
    return validKey
end

-- Fetch and execute script securely from server
local function fetchAndExecuteScript(scriptUrl)
    local scriptSuccess, scriptError = pcall(function()
        -- Ensure we’re fetching a secure script
        local scriptSource = game:HttpGet("https://your-secure-server.com/fetchScript?url=" .. scriptUrl)
        local loadedScript = loadstring(scriptSource)
        if loadedScript then
            local executionSuccess, executionError = pcall(loadedScript)
            if not executionSuccess then
                Library:ShowNotify("Execution Error", "Failed to execute script: " .. (executionError or "Unknown error"), 5)
            end
        else
            Library:ShowNotify("Load Error", "Failed to load script from URL.", 5)
        end
    end)

    if not scriptSuccess then
        Library:ShowNotify("Fetch Error", "Failed to fetch script source: " .. (scriptError or "Unknown error"), 5)
    end
end

