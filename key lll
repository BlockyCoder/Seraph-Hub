local admins = {"mohamedahmed12378", "itsyourboy_634", "ampokediger3"} -- Replace with actual admin usernames
local player = game.Players.LocalPlayer

-- Encrypting function (XOR-based)
local function encrypt(text, key)
    local result = {}
    for i = 1, #text do
        local keyChar = string.byte(key, (i % #key) + 1)
        local encryptedChar = string.char(bit32.bxor(string.byte(text, i), keyChar))
        table.insert(result, encryptedChar)
    end
    return table.concat(result)
end

-- Decrypting function
local function decrypt(text, key)
    return encrypt(text, key) -- XOR encryption is symmetric, same function for encryption/decryption
end

-- Secure admin check (more secure with server-side validation ideally)
local function isAdmin()
    -- Add server-side check here if possible
    for _, admin in ipairs(admins) do
        if player.Name == admin then
            return true
        end
    end
    return false
end

-- Encrypt and save keys to file
local function saveKeysToFile(keys)
    local success, errorMessage = pcall(function()
        local data = {Keys = keys}
        local jsonData = HttpService:JSONEncode(data)
        local encryptedData = encrypt(jsonData, EncryptionKey)
        writefile(FileName, encryptedData)
    end)

    if success then
        Library:ShowNotify("Save Success", "Keys successfully saved to file.", 5)
    else
        Library:ShowNotify("Save Error", "Error saving keys to file: " .. errorMessage, 5)
    end
end

-- Get the latest valid key and validate with encryption
local function getLatestValidKey()
    local validKey = nil
    local success, errorMessage = pcall(function()
        if isfile(FileName) then
            local encryptedData = readfile(FileName)
            local decryptedData = decrypt(encryptedData, EncryptionKey)
            local data = HttpService:JSONDecode(decryptedData)
            local keys = data.Keys

            for _, key in ipairs(keys) do
                local validationSuccess, keyResponse = pcall(function()
                    return game:HttpGet("https://redirect-api.work.ink/tokenValid/" .. key)
                end)

                if validationSuccess and keyResponse:find('{"valid":true}') then
                    validKey = key
                    Library:ShowNotify("Valid Key", "Valid key found!", 5)
                    break
                end
            end
        else
            Library:ShowNotify("File Error", "File does not exist.", 5)
        end
    end)

    if not success then
        Library:ShowNotify("Retrieval Error", "Error retrieving keys from file: " .. errorMessage, 5)
    end
    return validKey
end

